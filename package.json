{
	"name": "minecraft-anamorphic-art",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build && node scripts/verify-single-file.mjs",
		"check": "tsc -b --pretty false",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:watch": "vitest",
		"benchmark": "vitest bench --run tests/generator.bench.ts",
		"palette:extract": "tsx scripts/extract-palette.ts",
		"preview": "vite preview"
	},
	"dependencies": {
		"fflate": "^0.8.2",
		"three": "^0.178.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/pngjs": "^6.0.5",
		"@types/three": "^0.178.0",
		"pngjs": "^7.0.0",
		"tsx": "^4.23.0",
		"typescript": "^5.8.3",
		"vite": "^7.0.0",
		"vite-plugin-singlefile": "^2.2.0",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.29.3"
}
